# ======================
# Flask Project .gitignore
# ======================

# Virtual environment
venv/

# Python cache and compiled files
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pdb
*.egg
*.egg-info/
dist/
build/

# Flask instance folder (used for config or uploads)
instance/

# Environment variables
.env
*.env

# VS Code settings
.vscode/

# PyCharm settings
.idea/

# Logs
*.log

# System files
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.bak
*.swp